rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isRestaurantOwner(restaurantId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }

    function isValidRestaurant(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 200 &&
             data.ownerUid is string &&
             (!('lastTokenNumber' in data) || (data.lastTokenNumber is int && data.lastTokenNumber >= 0)) &&
             (!('lastTokenDate' in data) || (data.lastTokenDate is string)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('subscriptionStatus' in data) || data.subscriptionStatus in ['trial', 'active', 'expired', 'none']) &&
             (!('subscriptionPlan' in data) || data.subscriptionPlan in ['free_trial', 'monthly_199']) &&
             (!('trialEndDate' in data) || data.trialEndDate is string) &&
             (!('paymentExpiryDate' in data) || data.paymentExpiryDate is string);
    }

    function isValidQueueEntry(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.tokenNumber is int && data.tokenNumber > 0 &&
             data.status in ['waiting', 'called', 'completed'] &&
             data.members is string && data.members.size() > 0 && data.members.size() < 10 &&
             (!('customerPhone' in data) || data.customerPhone is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isTestUser(uid) {
      return uid == 'test-user-id-123';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /restaurants/{restaurantId} {
      // Allow anyone to get restaurant details
      allow get: if true;
      // Owners can list their restaurants. Allow test user for dev testing.
      allow list: if isAuthenticated() || true;
      
      // Only authenticated users can create a restaurant. Allow test user for dev testing.
      allow create: if (isAuthenticated() && request.resource.data.ownerUid == request.auth.uid && isValidRestaurant(request.resource.data)) ||
                      (isTestUser(request.resource.data.ownerUid) && isValidRestaurant(request.resource.data));
      
      // Allow owner to update everything, OR anyone to increment lastTokenNumber and lastTokenDate
      allow update: if (isAuthenticated() && resource.data.ownerUid == request.auth.uid && isValidRestaurant(request.resource.data)) ||
                    (isTestUser(resource.data.ownerUid) && isValidRestaurant(request.resource.data)) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastTokenNumber', 'lastTokenDate']) &&
                     request.resource.data.lastTokenNumber is int &&
                     request.resource.data.lastTokenDate is string);
      
      // Queue subcollection
      match /queue/{queueId} {
        // Anyone can read queue entries (needed for status check)
        allow read: if true;
        
        // Anyone can join the queue if data is valid
        allow create: if isValidQueueEntry(request.resource.data);
        
        // Only the restaurant owner can update or delete entries
        allow update: if isRestaurantOwner(restaurantId) || isTestUser(get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid);
        allow delete: if isRestaurantOwner(restaurantId) || isTestUser(get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid);
      }
    }
  }
}
